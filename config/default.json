{
  "shop": {
    "name": "Printel",
    "language": "ro",
    "currency": "RON",
    "timezone": "Europe/Bucharest",
    "homeUrl": "https://printel.ro"
  },
  "admin": {
    "url": "https://printel.ro/admin"
  },
  "themeConfig": {
    "logo": {
      "alt": "Printel",
      "src": "/assets/branding/printel-logo.jpeg",
      "width": 220,
      "height": 220
    },
    "copyRight": "© 2026 Printel. Toate drepturile rezervate."
  },
  "system": {
    "extensions": [
      {
        "name": "printelTheme",
        "resolve": "extensions/printelTheme",
        "enabled": true,
        "priority": 5
      },
      {
        "name": "printelLegalFooter",
        "resolve": "extensions/printelLegalFooter",
        "enabled": true,
        "priority": 10
      },
      {
        "name": "printelCookieBanner",
        "resolve": "extensions/printelCookieBanner",
        "enabled": true,
        "priority": 20
      }
    ]
  },
  "security": {
    "enableHttps": false,
    "sessionTimeout": 3600
  },
  "database": {
    "host": "${DB_HOST}",
    "port": "${DB_PORT}",
    "database": "${DB_NAME}",
    "user": "${DB_USER}",
    "password": "${DB_PASSWORD}",
    "sslmode": "${DB_SSLMODE:disable}"
  }
}